# DriveX Environment Configuration
# Copy this file to .env and fill in your values

# Application Secret Key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-super-secret-key-change-this-in-production

# Session encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-fernet-encryption-key-here

# Session timeout in seconds (default: 3600 = 1 hour)
SESSION_TIMEOUT=3600

# Application host and port
HOST=0.0.0.0
PORT=8000

# Debug mode (set to False in production)
DEBUG=False

# Max upload size in MB
MAX_UPLOAD_SIZE_MB=5000

# Audit log file path
AUDIT_LOG_PATH=logs/audit.log
